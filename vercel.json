{
    "version": 2,
    "rewrites": [
        {
            "source": "/api/trpc/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/index.ts"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}